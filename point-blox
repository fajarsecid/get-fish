-- LOGIKA AIMBOT
-- ==========================================
local LockedTarget = nil

local function IsVisible(targetPart)
    if not targetPart then return false end
    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    local rayResult = workspace:Raycast(
        Camera.CFrame.Position,
        (targetPart.Position - Camera.CFrame.Position).Unit * 5000,
        rayParams
    )
    return rayResult and rayResult.Instance:IsDescendantOf(targetPart.Parent) or false
end

local function GetNewTarget3D()
    local closest, shortestDist = nil, math.huge
    for _, item in pairs(ValidEntities) do
        local hum = item:FindFirstChildOfClass("Humanoid")
        local targetPart = GetTargetPart(item)
        if item.Parent and hum and hum.Health > 0 and targetPart
            and IsEnemy(item) and IsVisible(targetPart)
            and not item:FindFirstChildOfClass("ForceField") then
            local dist = (Camera.CFrame.Position - targetPart.Position).Magnitude
            if dist < shortestDist then
                shortestDist = dist
                closest = item
            end
        end
    end
    return closest
end

RunService.RenderStepped:Connect(function()
    if AimbotAktif then
        local targetValid = false
        if LockedTarget and LockedTarget.Parent then
            local hum = LockedTarget:FindFirstChildOfClass("Humanoid")
            local targetPart = GetTargetPart(LockedTarget)
            if hum and hum.Health > 0 and targetPart
                and IsEnemy(LockedTarget)
                and IsVisible(targetPart)
                and not LockedTarget:FindFirstChildOfClass("ForceField") then
                targetValid = true
            end
        end
        if not targetValid then
            LockedTarget = GetNewTarget3D()
        end
        if LockedTarget then
            local targetPart = GetTargetPart(LockedTarget)
            if targetPart then
                Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, targetPart.Position)
            end
        end
    else
        LockedTarget = nil
    end
end)

