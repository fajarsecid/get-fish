local function GetTargetPart(char)
    if not char then return nil end
    if AimTargetMode == "Head" then
        return char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
    elseif AimTargetMode == "Body" then
        return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    elseif AimTargetMode == "Random" then
        local now = tick()
        if now - LastRandomAimUpdate > 1.5 then 
            RandomAimPartCache = (math.random() > 0.5) and "Head" or "HumanoidRootPart"
            LastRandomAimUpdate = now
        end
        return char:FindFirstChild(RandomAimPartCache) or char:FindFirstChild("HumanoidRootPart")
    end
end

