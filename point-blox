-- LOGIKA TELEPORT (HEARTBEAT - TWEENSERVICE FIX)
-- ==========================================
local TPTween = nil
local LastTweenTargetPos = Vector3.zero

RunService.Heartbeat:Connect(function(deltaTime) 
    if AutoTeleportAktif and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local myPos = LocalPlayer.Character.HumanoidRootPart
        local targetCharToTP = nil
        local abandonedPlayer = nil 

        if ModeTP == "Auto Cycle" then
            local needsNewTarget = false
            if CurrentTargetPlayer then
                if not CurrentTargetPlayer.Parent then needsNewTarget = true; abandonedPlayer = CurrentTargetPlayer
                elseif CurrentTargetPlayer.Character ~= CurrentTargetCharacter then needsNewTarget = true; abandonedPlayer = CurrentTargetPlayer
                elseif CurrentTargetCharacter and CurrentTargetCharacter:FindFirstChild("HumanoidRootPart") and CurrentTargetCharacter:FindFirstChild("Humanoid") then
                    if HindariShield and CurrentTargetCharacter:FindFirstChildOfClass("ForceField") then
                        needsNewTarget = true; abandonedPlayer = CurrentTargetPlayer
                    elseif CurrentTargetCharacter.Humanoid.Health <= 0 then needsNewTarget = true; abandonedPlayer = CurrentTargetPlayer
                    elseif LastTargetPos then
                        local distanceMoved = (CurrentTargetCharacter.HumanoidRootPart.Position - LastTargetPos).Magnitude
                        if distanceMoved > 60 then needsNewTarget = true; abandonedPlayer = CurrentTargetPlayer
                        elseif distanceMoved < 0.1 then TargetStaticTime = TargetStaticTime + deltaTime; if TargetStaticTime > 1.5 then needsNewTarget = true; abandonedPlayer = CurrentTargetPlayer end
                        else TargetStaticTime = 0 end
                    end
                    if not needsNewTarget then LastTargetPos = CurrentTargetCharacter.HumanoidRootPart.Position end
                else needsNewTarget = true; abandonedPlayer = CurrentTargetPlayer end
            else needsNewTarget = true end

            if needsNewTarget then
                CurrentTargetPlayer, CurrentTargetCharacter, LastTargetPos, TargetStaticTime = nil, nil, nil, 0 
                local validEnemies = {}
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p ~= abandonedPlayer and p.Character and IsEnemy(p.Character) and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 and p.Character:FindFirstChild("HumanoidRootPart") then
                        if not (HindariShield and p.Character:FindFirstChildOfClass("ForceField")) then table.insert(validEnemies, p) end
                    end
                end
                if #validEnemies == 0 and abandonedPlayer then
                    for _, p in pairs(Players:GetPlayers()) do
                        if p ~= LocalPlayer and p.Character and IsEnemy(p.Character) and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 and p.Character:FindFirstChild("HumanoidRootPart") then 
                            if not (HindariShield and p.Character:FindFirstChildOfClass("ForceField")) then table.insert(validEnemies, p) end
                        end
                    end
                end
                if #validEnemies > 0 then 
                    CurrentTargetPlayer = validEnemies[math.random(1, #validEnemies)]
                    CurrentTargetCharacter = CurrentTargetPlayer.Character
                    if CurrentTargetCharacter and CurrentTargetCharacter:FindFirstChild("HumanoidRootPart") then LastTargetPos = CurrentTargetCharacter.HumanoidRootPart.Position end
                end
            end
            if CurrentTargetPlayer and CurrentTargetCharacter then targetCharToTP = CurrentTargetCharacter end

        elseif ModeTP == "Pilih Lawan" then
            local p = Players:FindFirstChild(TargetLawan)
            if p and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 and IsEnemy(p.Character) then 
                if not (HindariShield and p.Character:FindFirstChildOfClass("ForceField")) then targetCharToTP = p.Character end
            end
        end

        local function TweenTeleport(targetCFrame)
            local dist = (myPos.Position - targetCFrame.Position).Magnitude
            if dist > 15 then
                myPos.Velocity = Vector3.zero 
                if not TPTween or (LastTweenTargetPos - targetCFrame.Position).Magnitude > 5 then
                    if TPTween then TPTween:Cancel() end
                    LastTweenTargetPos = targetCFrame.Position
                    
                    local speedMult = TPBypassSpeed * 15 
                    local timeReq = dist / speedMult
                    
                    TPTween = TweenService:Create(myPos, TweenInfo.new(timeReq, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
                    TPTween:Play()
                end
            else
                if TPTween then TPTween:Cancel(); TPTween = nil end
                myPos.CFrame = targetCFrame
            end
        end

        if targetCharToTP and targetCharToTP:FindFirstChild("HumanoidRootPart") then
            local targetPos = targetCharToTP.HumanoidRootPart.CFrame * CFrame.new(0, 3, TeleportJarak)
            TweenTeleport(targetPos)
            
            if AimbotAktif then
                local aimPart = GetTargetPart(targetCharToTP)
                if aimPart then Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, aimPart.Position) end
            end
        elseif BaseCFrame then
            TweenTeleport(BaseCFrame)
        else
            if TPTween then TPTween:Cancel(); TPTween = nil end
        end
    else
        if TPTween then TPTween:Cancel(); TPTween = nil end
    end
end)

