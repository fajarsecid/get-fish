local LockedTarget = nil
local function IsVisible(targetPart)
    if not targetPart then return false end
    local rayParams = RaycastParams.new(); rayParams.FilterDescendantsInstances = {LocalPlayer.Character, Camera}; rayParams.FilterType = Enum.RaycastFilterType.Exclude
    local rayResult = workspace:Raycast(Camera.CFrame.Position, (targetPart.Position - Camera.CFrame.Position).Unit * 5000, rayParams)
    return rayResult and rayResult.Instance:IsDescendantOf(targetPart.Parent) or false
end
local function GetNewTarget3D()
    local closest, shortestDist = nil, math.huge
    for _, item in pairs(ValidEntities) do
        local hum = item:FindFirstChildOfClass("Humanoid")
        local targetPart = GetTargetPart(item)
        if item.Parent and hum and hum.Health > 0 and targetPart and IsEnemy(item) and IsVisible(targetPart) and not (HindariShield and item:FindFirstChildOfClass("ForceField")) then
            local dist = (Camera.CFrame.Position - targetPart.Position).Magnitude
            if dist < shortestDist then shortestDist = dist; closest = item end
        end
    end
    return closest
end
local function GetClosestEnemy2D()
    local closest, shortestDist = nil, math.huge
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    for _, item in pairs(ValidEntities) do
        local hum = item:FindFirstChildOfClass("Humanoid")
        local targetPart = GetTargetPart(item)
        if item.Parent and hum and hum.Health > 0 and targetPart and IsEnemy(item) and not (HindariShield and item:FindFirstChildOfClass("ForceField")) then
            local pos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
            if onScreen then
                local dist = (center - Vector2.new(pos.X, pos.Y)).Magnitude
                if dist < shortestDist then shortestDist = dist; closest = item end
            end
        end
    end
    return closest
end

